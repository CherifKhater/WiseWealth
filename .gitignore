# AI Assistant specific (keep tracked)
# .cursorrules - KEEP (symlink to _PROJECT_CONTEXT.md)
# .clinerules - KEEP (symlink to _PROJECT_CONTEXT.md)
# _PROJECT_CONTEXT.md - KEEP (master context)
# _CODEBASE_INDEX.md - KEEP (code index)
# _INDEXING_STRATEGY.md - KEEP (indexing docs)
# _SYNC_SUMMARY.md - KEEP (sync reference)
# CLAUDE.md - KEEP (assistant-specific)
# GEMINI.md - KEEP (assistant-specific)
# AGENTS.md - KEEP (assistant-specific)

# AI Assistant caches/indexes (DON'T track)
.cursor/
.continue/
.aider*
*.ai-cache
_AUTO_INDEX.json         # Auto-generated, don't track
_AUTO_INDEX.md           # Auto-generated, don't track

# Milvus vector database (DON'T track)
volumes/                 # Milvus data directory (Docker volumes)
.volumes/                # Alternative volumes directory (if used)
milvus-backup-*.tar.gz   # Database backups

